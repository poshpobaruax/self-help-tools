<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dopamine Control System</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #000000;
            color: #d1d5db;
        }
        
        .task-item {
            transition: all 0.2s ease;
        }
        
        .task-incomplete {
            background-color: #0a0a0a;
            border-left: 2px solid #374151;
        }
        
        .task-completed {
            background-color: #111111;
            border-left: 2px solid #ffffff;
            opacity: 0.5;
        }
        
        .task-prioritized {
            background-color: #1a1a1a;
            border-left: 4px solid #ffffff;
        }

        .card {
            background-color: #050505;
            border: 1px solid #262626;
        }

        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-track { background: #000000; }
        ::-webkit-scrollbar-thumb { background: #333333; }
        ::-webkit-scrollbar-thumb:hover { background: #666666; }
        
        .ai-glow {
            animation: pulse-glow 3s infinite alternate;
        }
        @keyframes pulse-glow {
            0% { box-shadow: 0 0 5px 0 rgba(255, 255, 255, 0.1); }
            100% { box-shadow: 0 0 15px 2px rgba(255, 255, 255, 0.2); }
        }
    </style>
</head>
<body class="min-h-screen flex flex-col items-center py-8 px-4 sm:px-8">

    <div id="dashboard" class="w-full max-w-6xl w-full flex flex-col gap-6 transition-opacity duration-500">
        
        <header class="flex flex-col sm:flex-row justify-between items-center bg-black p-6 border-b border-gray-800">
            <div>
                <h1 class="text-3xl font-extrabold tracking-tight text-white uppercase">System Dashboard</h1>
                <div class="flex items-center gap-3 mt-2">
                    <span id="current-day-label" class="text-white font-bold bg-gray-800 px-2 py-0.5 text-xs uppercase tracking-widest"></span>
                    <p class="text-gray-500 text-xs uppercase tracking-widest">Discipline equals freedom.</p>
                </div>
            </div>
            <button onclick="toggleFocusMode()" class="mt-4 sm:mt-0 bg-white text-black hover:bg-gray-200 px-6 py-2 text-sm font-bold uppercase tracking-wider transition-colors duration-200">
                Focus Mode
            </button>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            
            <div class="flex flex-col gap-6 lg:col-span-1">
                <div class="card p-6">
                    <h2 class="text-sm font-bold mb-4 text-gray-400 uppercase tracking-widest">Detox Timer</h2>
                    <div class="text-center mb-6">
                        <div id="timer-display" class="text-4xl font-mono font-bold text-white tracking-wider">00:00:00</div>
                        <div id="timer-days" class="text-xs text-gray-500 mt-2 uppercase tracking-widest">0 Days</div>
                    </div>
                    <div class="flex gap-2 justify-center">
                        <button onclick="toggleTimer()" id="btn-timer-toggle" class="flex-1 bg-transparent text-white border border-gray-600 hover:bg-gray-900 py-2 text-xs uppercase tracking-widest font-bold transition-colors">Start</button>
                        <button onclick="resetTimer()" class="flex-1 bg-transparent text-gray-500 border border-gray-800 hover:text-white py-2 text-xs uppercase tracking-widest font-bold transition-colors">Reset</button>
                    </div>
                </div>

                <div class="card p-6">
                    <h2 class="text-sm font-bold mb-4 text-gray-400 uppercase tracking-widest">Streak Data</h2>
                    <div class="grid grid-cols-2 gap-4 mb-6 text-center border-b border-gray-800 pb-6">
                        <div>
                            <div class="text-[10px] text-gray-600 uppercase tracking-widest">Current</div>
                            <div id="current-streak" class="text-3xl font-bold text-white mt-1">0</div>
                        </div>
                        <div>
                            <div class="text-[10px] text-gray-600 uppercase tracking-widest">Longest</div>
                            <div id="longest-streak" class="text-3xl font-bold text-gray-400 mt-1">0</div>
                        </div>
                    </div>
                    <div class="flex flex-col gap-3">
                        <button onclick="triggerRelapse()" class="w-full bg-transparent text-gray-400 border border-gray-700 hover:bg-white hover:text-black py-3 text-xs uppercase tracking-widest font-bold transition-all">
                            Log Relapse (Reset)
                        </button>
                        <button onclick="handleKillUrge()" class="w-full bg-gray-900 text-white border border-gray-600 hover:bg-gray-800 py-2 text-xs uppercase tracking-widest font-bold transition-all flex items-center justify-center gap-2">
                            [ AI ] Kill Urge
                        </button>
                    </div>
                </div>
            </div>

            <div class="card p-6 lg:col-span-1 flex flex-col max-h-[600px]">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-sm font-bold text-gray-400 uppercase tracking-widest">Daily Protocol</h2>
                    <span id="task-ratio" class="text-xs font-mono text-gray-500">0/0</span>
                </div>
                
                <form id="add-task-form" class="mb-6 flex gap-2" onsubmit="addTask(event)">
                    <input type="text" id="new-task-input" placeholder="Add protocol..." class="flex-1 bg-transparent border-b border-gray-700 px-2 py-1 text-sm text-white focus:outline-none focus:border-white transition-colors rounded-none" required>
                    <button type="submit" class="text-gray-500 hover:text-white px-3 font-mono">+</button>
                </form>

                <div id="task-list" class="flex-1 overflow-y-auto pr-2 space-y-2">
                    <!-- Tasks injected via JS -->
                </div>
            </div>

            <div class="card p-6 lg:col-span-1 flex flex-col">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-sm font-bold text-gray-400 uppercase tracking-widest">Metrics</h2>
                    <div class="flex border border-gray-800">
                        <button onclick="setView('daily')" id="btn-view-daily" class="px-3 py-1 text-[10px] font-bold uppercase tracking-widest bg-white text-black">Daily</button>
                        <button onclick="setView('total')" id="btn-view-total" class="px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-gray-500 hover:text-white">Total</button>
                    </div>
                </div>
                
                <div class="mb-8">
                    <div class="flex justify-between text-xs mb-2 uppercase tracking-widest">
                        <span id="progress-label" class="text-gray-500">Completion</span>
                        <span id="progress-percent-text" class="font-mono text-white">0%</span>
                    </div>
                    <div class="w-full bg-gray-900 h-1 overflow-hidden">
                        <div id="progress-bar" class="bg-white h-1 transition-all duration-500 ease-out" style="width: 0%"></div>
                    </div>
                </div>

                <div class="flex-1 relative w-full h-48 sm:h-auto min-h-[200px]">
                    <canvas id="progressChart"></canvas>
                </div>
            </div>

        </div>
    </div>

    <!-- FOCUS MODE OVERLAY -->
    <div id="focus-mode" class="hidden fixed inset-0 bg-black z-40 flex flex-col items-center justify-center p-6 text-center transition-opacity duration-500 opacity-0 pointer-events-none">
        <div class="max-w-2xl w-full">
            <h2 class="text-gray-600 uppercase tracking-[0.4em] text-xs font-bold mb-12">Focus Protocol</h2>
            <div id="focus-task-display" class="text-3xl sm:text-4xl font-bold text-white mb-16 leading-tight uppercase tracking-wide">
                Execute.
            </div>
            <div class="mb-16">
                <div id="focus-timer-display" class="text-6xl font-mono text-gray-400 tracking-widest">00:00:00</div>
            </div>
            <button onclick="toggleFocusMode()" class="bg-transparent text-gray-500 hover:text-white border border-gray-800 px-8 py-3 text-xs uppercase tracking-widest font-bold transition-colors">
                Abort Focus
            </button>
        </div>
    </div>

    <!-- AI COACH MODAL -->
    <div id="ai-modal" class="hidden fixed inset-0 bg-black/90 z-50 flex flex-col items-center justify-center p-4 transition-opacity duration-300 opacity-0 pointer-events-none">
        <div class="bg-black border border-gray-700 p-8 max-w-xl w-full ai-glow relative">
            <div class="flex justify-between items-start mb-8 border-b border-gray-800 pb-4">
                <h3 id="ai-modal-title" class="text-sm font-bold text-white uppercase tracking-widest">
                    [ AI Processing ]
                </h3>
                <button onclick="closeAIModal()" class="text-gray-600 hover:text-white font-mono">X</button>
            </div>
            <div id="ai-modal-content" class="text-gray-300 text-sm leading-relaxed min-h-[80px] font-mono flex items-center">
                <!-- AI Text -->
            </div>
            <div class="mt-10 flex justify-end">
                <button onclick="closeAIModal()" class="bg-white text-black hover:bg-gray-300 px-6 py-2 text-xs uppercase tracking-widest font-bold transition-colors">Acknowledge</button>
            </div>
        </div>
    </div>

    <!-- CUSTOM CONFIRM MODAL -->
    <div id="custom-modal" class="hidden fixed inset-0 bg-black/90 z-[60] flex flex-col items-center justify-center p-4 transition-opacity duration-300 opacity-0 pointer-events-none">
        <div class="bg-black border border-gray-700 p-8 max-w-sm w-full">
            <h3 id="custom-modal-title" class="text-sm font-bold text-white uppercase tracking-widest mb-6">Confirm Action</h3>
            <input type="text" id="custom-modal-input" class="hidden w-full bg-transparent border-b border-gray-600 px-2 py-2 text-white focus:outline-none focus:border-white mb-8 font-mono text-sm rounded-none" />
            <div class="flex justify-end gap-4">
                <button onclick="closeCustomModal(false)" class="text-gray-500 hover:text-white text-xs uppercase tracking-widest font-bold">Cancel</button>
                <button id="custom-modal-confirm" class="bg-white text-black px-4 py-2 text-xs uppercase tracking-widest font-bold">Confirm</button>
            </div>
        </div>
    </div>

    <script>
        // ==========================================
        // CUSTOM MODAL LOGIC
        // ==========================================
        let modalResolve = null;

        function showCustomModal(title, isPrompt = false, defaultValue = "") {
            return new Promise((resolve) => {
                modalResolve = resolve;
                const modal = document.getElementById('custom-modal');
                const titleEl = document.getElementById('custom-modal-title');
                const inputEl = document.getElementById('custom-modal-input');
                const confirmBtn = document.getElementById('custom-modal-confirm');
                
                titleEl.innerText = title;
                
                if (isPrompt) {
                    inputEl.classList.remove('hidden');
                    inputEl.value = defaultValue;
                    inputEl.focus();
                } else {
                    inputEl.classList.add('hidden');
                }
                
                confirmBtn.onclick = () => closeCustomModal(isPrompt ? inputEl.value : true);
                
                modal.classList.remove('hidden');
                setTimeout(() => modal.classList.remove('opacity-0', 'pointer-events-none'), 10);
            });
        }

        function closeCustomModal(result) {
            const modal = document.getElementById('custom-modal');
            modal.classList.add('opacity-0', 'pointer-events-none');
            setTimeout(() => modal.classList.add('hidden'), 300);
            if (modalResolve) modalResolve(result);
        }

        // ==========================================
        // GEMINI API INTEGRATION
        // ==========================================
        const apiKey = ""; 

        async function fetchGeminiAPI(prompt, systemInstruction) {
            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
            const payload = {
                contents: [{ parts: [{ text: prompt }] }],
                systemInstruction: { parts: [{ text: systemInstruction }] }
            };

            const delays = [1000, 2000, 4000, 8000, 16000];
            for (let i = 0; i < 5; i++) {
                try {
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    
                    if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
                    const data = await response.json();
                    return data.candidates?.[0]?.content?.parts?.[0]?.text || "NO RESPONSE. EXECUTE PROTOCOL.";
                } catch (error) {
                    if (i === 4) return "SYSTEM OFFLINE. RELY ON DISCIPLINE.";
                    await new Promise(res => setTimeout(res, delays[i]));
                }
            }
        }

        function openAIModal(title, initialText = "PROCESSING...") {
            const modal = document.getElementById('ai-modal');
            document.getElementById('ai-modal-title').innerText = `[ ${title} ]`;
            document.getElementById('ai-modal-content').innerHTML = `<span class="animate-pulse">${initialText}</span>`;
            modal.classList.remove('hidden');
            setTimeout(() => modal.classList.remove('opacity-0', 'pointer-events-none'), 10);
        }

        function closeAIModal() {
            const modal = document.getElementById('ai-modal');
            modal.classList.add('opacity-0', 'pointer-events-none');
            setTimeout(() => modal.classList.add('hidden'), 300);
        }

        async function handleKillUrge() {
            const currentStreakDays = Math.floor((Date.now() - state.relapse.lastDate) / 86400000);
            openAIModal("URGE OVERRIDE", "ACCESSING CRITICAL LOGIC...");
            const systemPrompt = "You are a cold, logic-driven machine prioritizing discipline over human comfort. Provide a strict, 2-sentence reality check to kill a dopamine craving. Use harsh, clinical language.";
            const userPrompt = `I am feeling an urge to relapse. Clean streak: ${currentStreakDays} days. Obliterate this urge with logic.`;
            const response = await fetchGeminiAPI(userPrompt, systemPrompt);
            document.getElementById('ai-modal-content').innerText = response;
        }

        async function handleTaskAdvice(taskText, event) {
            if(event) event.stopPropagation();
            openAIModal("TASK STRATEGY", `ANALYZING TASK: ${taskText}...`);
            const systemPrompt = "Provide hyper-practical, clinical advice. 2 sentences maximum. Sentence 1: Mechanical micro-step to start immediately. Sentence 2: Logical consequence of failure.";
            const userPrompt = `Task: "${taskText}". Provide execution logic.`;
            const response = await fetchGeminiAPI(userPrompt, systemPrompt);
            document.getElementById('ai-modal-content').innerText = response;
        }

        // ==========================================
        // STATE MANAGEMENT
        // ==========================================
        const defaultTasks = [
            { id: 1, text: "Zero porn or masturbation", completed: false, prioritized: false, critical: true },
            { id: 2, text: "Zero short-form content", completed: false, prioritized: false, critical: true },
            { id: 3, text: "5 hours deep work", completed: false, prioritized: false, critical: true },
            { id: 4, text: "Phone locked in another room", completed: false, prioritized: false, critical: true },
            { id: 5, text: "Wake up at 6:00 AM", completed: false, prioritized: false, critical: true },
            { id: 6, text: "Cold water face wash", completed: false, prioritized: false, critical: false },
            { id: 7, text: "2 hours active recall", completed: false, prioritized: false, critical: false },
            { id: 8, text: "Zero processed sugar", completed: false, prioritized: false, critical: false },
            { id: 9, text: "30 mins intense exercise", completed: false, prioritized: false, critical: false },
            { id: 10, text: "1 hour mistake review", completed: false, prioritized: false, critical: false },
            { id: 11, text: "No music during work", completed: false, prioritized: false, critical: false },
            { id: 12, text: "Drink 3 liters water", completed: false, prioritized: false, critical: false },
            { id: 13, text: "10 mins meditation", completed: false, prioritized: false, critical: false },
            { id: 14, text: "Plan tomorrow schedule", completed: false, prioritized: false, critical: false },
            { id: 15, text: "Devices off 1 hour prior sleep", completed: false, prioritized: false, critical: false }
        ];

        const defaultState = {
            lastDate: new Date().toLocaleDateString(),
            tasks: defaultTasks,
            detox: { isRunning: false, startTime: null, elapsed: 0 },
            relapse: { lastDate: Date.now(), longest: 0 },
            history: []
        };

        let state = JSON.parse(localStorage.getItem('dopamineState')) || defaultState;
        
        if (state.tasks.length !== 15 || state.tasks[0].text !== defaultTasks[0].text) {
             state.tasks = defaultTasks.map(dt => ({ ...dt }));
             localStorage.setItem('dopamineState', JSON.stringify(state));
        }
        
        let detoxInterval;
        let chartInstance;
        let currentView = 'daily';

        function init() {
            updateDayLabel();
            checkDailyReset();
            renderTasks();
            updateStreakUI();
            initChart();
            updateProgressUI();
            
            if (state.detox.isRunning) {
                document.getElementById('btn-timer-toggle').innerText = 'PAUSE';
                document.getElementById('btn-timer-toggle').className = "flex-1 bg-white text-black py-2 text-xs uppercase tracking-widest font-bold transition-colors";
                startTimerLoop();
            } else {
                renderTimerDisplay(state.detox.elapsed);
            }
            setInterval(checkDailyReset, 60000); 
        }

        function saveState() {
            localStorage.setItem('dopamineState', JSON.stringify(state));
        }

        function checkDailyReset() {
            const todayLoc = new Date().toLocaleDateString();
            if (state.lastDate !== todayLoc) {
                const completedCount = state.tasks.filter(t => t.completed).length;
                const total = state.tasks.length;
                const percent = total > 0 ? (completedCount / total) * 100 : 0;
                
                state.history.push({ date: state.lastDate, percentage: percent });
                if (state.history.length > 30) state.history.shift(); 
                
                let missedIds = new Set();
                let criticalMissed = false;

                state.tasks.forEach(t => {
                    if (!t.completed) {
                        missedIds.add(t.id);
                        if (t.critical) criticalMissed = true;
                    }
                    t.completed = false; 
                });

                if (criticalMissed) {
                    const now = Date.now();
                    const currentStreakDays = Math.floor((now - state.relapse.lastDate) / 86400000);
                    if (currentStreakDays > state.relapse.longest) state.relapse.longest = currentStreakDays;
                    state.relapse.lastDate = now;
                }

                state.tasks.forEach(t => t.prioritized = missedIds.has(t.id));
                state.tasks.sort((a, b) => (b.prioritized === true) - (a.prioritized === true));
                state.lastDate = todayLoc;
                
                saveState();
                renderTasks();
                updateProgressUI();
                updateChart();
                updateStreakUI();
                updateDayLabel();
            }
        }

        function updateDayLabel() {
            const days = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
            document.getElementById('current-day-label').innerText = days[new Date().getDay()];
        }

        function toggleTimer() {
            const btn = document.getElementById('btn-timer-toggle');
            if (state.detox.isRunning) {
                state.detox.elapsed += (Date.now() - state.detox.startTime);
                state.detox.isRunning = false;
                state.detox.startTime = null;
                clearInterval(detoxInterval);
                btn.innerText = 'START';
                btn.className = "flex-1 bg-transparent text-white border border-gray-600 hover:bg-gray-900 py-2 text-xs uppercase tracking-widest font-bold transition-colors";
            } else {
                state.detox.startTime = Date.now();
                state.detox.isRunning = true;
                btn.innerText = 'PAUSE';
                btn.className = "flex-1 bg-white text-black py-2 text-xs uppercase tracking-widest font-bold transition-colors";
                startTimerLoop();
            }
            saveState();
        }

        async function resetTimer() {
            if (await showCustomModal("CONFIRM TIMER RESET")) {
                state.detox = { isRunning: false, startTime: null, elapsed: 0 };
                clearInterval(detoxInterval);
                const btn = document.getElementById('btn-timer-toggle');
                btn.innerText = 'START';
                btn.className = "flex-1 bg-transparent text-white border border-gray-600 hover:bg-gray-900 py-2 text-xs uppercase tracking-widest font-bold transition-colors";
                renderTimerDisplay(0);
                saveState();
            }
        }

        function startTimerLoop() {
            clearInterval(detoxInterval);
            detoxInterval = setInterval(() => {
                renderTimerDisplay(state.detox.elapsed + (Date.now() - state.detox.startTime));
            }, 1000);
        }

        function renderTimerDisplay(ms) {
            let totalSecs = Math.floor(ms / 1000);
            const days = Math.floor(totalSecs / 86400);
            totalSecs %= 86400;
            const hours = Math.floor(totalSecs / 3600);
            totalSecs %= 3600;
            const mins = Math.floor(totalSecs / 60);
            const secs = totalSecs % 60;
            const fmt = n => n.toString().padStart(2, '0');
            const str = `${fmt(hours)}:${fmt(mins)}:${fmt(secs)}`;
            document.getElementById('timer-display').innerText = str;
            document.getElementById('focus-timer-display').innerText = str;
            document.getElementById('timer-days').innerText = `${days} DAY${days !== 1 ? 'S' : ''}`;
        }

        async function triggerRelapse() {
            if (await showCustomModal("CONFIRM RELAPSE AND DATA RESET")) {
                const now = Date.now();
                const currDays = Math.floor((now - state.relapse.lastDate) / 86400000);
                if (currDays > state.relapse.longest) state.relapse.longest = currDays;
                state.relapse.lastDate = now;
                saveState();
                updateStreakUI();
            }
        }

        function updateStreakUI() {
            document.getElementById('current-streak').innerText = Math.floor((Date.now() - state.relapse.lastDate) / 86400000);
            document.getElementById('longest-streak').innerText = state.relapse.longest;
        }

        function addTask(e) {
            e.preventDefault();
            const input = document.getElementById('new-task-input');
            if (input.value.trim()) {
                state.tasks.push({ id: Date.now(), text: input.value.trim(), completed: false, prioritized: false, critical: false });
                input.value = '';
                saveState();
                renderTasks();
                updateProgressUI();
                updateChart();
            }
        }

        function toggleTask(id) {
            const t = state.tasks.find(t => t.id === id);
            if (t) {
                t.completed = !t.completed;
                saveState();
                renderTasks();
                updateProgressUI();
                updateChart();
            }
        }

        async function editTask(id, event) {
            if(event) event.stopPropagation();
            const t = state.tasks.find(t => t.id === id);
            if (t) {
                const res = await showCustomModal("EDIT PROTOCOL", true, t.text);
                if (res && res.trim() !== "") {
                    t.text = res.trim();
                    saveState();
                    renderTasks();
                }
            }
        }

        async function deleteTask(id, event) {
            if(event) event.stopPropagation();
            if (await showCustomModal("DELETE PROTOCOL?")) {
                state.tasks = state.tasks.filter(t => t.id !== id);
                saveState();
                renderTasks();
                updateProgressUI();
                updateChart();
            }
        }

        function renderTasks() {
            const container = document.getElementById('task-list');
            container.innerHTML = '';
            state.tasks.forEach(t => {
                const isPrio = t.prioritized && !t.completed;
                const div = document.createElement('div');
                div.className = `task-item flex items-center justify-between p-3 cursor-pointer ${t.completed ? 'task-completed' : (isPrio ? 'task-prioritized' : 'task-incomplete')}`;
                div.innerHTML = `
                    <div class="flex items-center gap-3 flex-1" onclick="toggleTask(${t.id})">
                        <div class="text-xs font-mono w-5 h-5 flex justify-center items-center border ${t.completed ? 'border-white text-white' : 'border-gray-600 text-transparent'}">${t.completed ? 'X' : ''}</div>
                        <div class="flex flex-col">
                            <span class="${t.completed ? 'text-gray-500 line-through' : 'text-gray-300'} text-sm font-medium">${t.text}</span>
                            <div class="flex gap-2 items-center mt-1">
                                ${t.critical && !t.completed ? '<span class="text-[9px] text-gray-400 font-bold uppercase tracking-widest border border-gray-700 px-1">CORE</span>' : ''}
                                ${isPrio ? '<span class="text-[9px] text-white font-bold uppercase tracking-widest bg-gray-800 px-1">MISSED</span>' : ''}
                            </div>
                        </div>
                    </div>
                    <div class="flex gap-3 opacity-30 hover:opacity-100 transition-opacity">
                        <button onclick="handleTaskAdvice('${t.text.replace(/'/g, "\\'")}', event)" class="text-xs text-white font-mono hover:text-gray-400" title="AI">[AI]</button>
                        <button onclick="editTask(${t.id}, event)" class="text-xs text-gray-500 hover:text-white font-mono">EDIT</button>
                        <button onclick="deleteTask(${t.id}, event)" class="text-xs text-gray-500 hover:text-white font-mono">DEL</button>
                    </div>
                `;
                container.appendChild(div);
            });
        }

        function setView(v) {
            currentView = v;
            document.getElementById('btn-view-daily').className = `px-3 py-1 text-[10px] font-bold uppercase tracking-widest ${v === 'daily' ? 'bg-white text-black' : 'text-gray-500 hover:text-white bg-transparent'}`;
            document.getElementById('btn-view-total').className = `px-3 py-1 text-[10px] font-bold uppercase tracking-widest ${v === 'total' ? 'bg-white text-black' : 'text-gray-500 hover:text-white bg-transparent'}`;
            document.getElementById('progress-label').innerText = v === 'daily' ? 'TODAY' : 'AVERAGE';
            updateProgressUI();
            updateChart();
        }

        function updateProgressUI() {
            const total = state.tasks.length;
            const comp = state.tasks.filter(t => t.completed).length;
            const pctDaily = total === 0 ? 0 : Math.round((comp / total) * 100);
            const pctTotal = Math.round((state.history.reduce((s, h) => s + h.percentage, 0) + pctDaily) / (state.history.length + 1));
            const disp = currentView === 'daily' ? pctDaily : pctTotal;
            document.getElementById('task-ratio').innerText = `${comp}/${total}`;
            document.getElementById('progress-percent-text').innerText = `${disp}%`;
            document.getElementById('progress-bar').style.width = `${disp}%`;
            const next = state.tasks.find(t => !t.completed);
            const el = document.getElementById('focus-task-display');
            el.innerText = next ? next.text : (total > 0 ? "ALL PROTOCOLS COMPLETE" : "NO PROTOCOLS");
            el.className = `text-3xl sm:text-4xl font-bold mb-16 leading-tight uppercase tracking-wide ${next ? 'text-white' : 'text-gray-600'}`;
        }

        function initChart() {
            chartInstance = new Chart(document.getElementById('progressChart').getContext('2d'), {
                type: 'line',
                data: { labels: [], datasets: [{ label: 'DATA', data: [], borderColor: '#ffffff', backgroundColor: 'rgba(255,255,255,0.05)', borderWidth: 1, pointBackgroundColor: '#ffffff', pointRadius: 2, fill: true, tension: 0 }] },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false }, tooltip: { backgroundColor: '#000', titleColor: '#fff', bodyColor: '#fff', borderColor: '#333', borderWidth: 1 } }, scales: { y: { beginAtZero: true, max: 100, grid: { color: '#1a1a1a' }, ticks: { color: '#666', stepSize: 25 } }, x: { grid: { display: false }, ticks: { color: '#666' } } } }
            });
            updateChart(); 
        }

        function updateChart() {
            if (!chartInstance) return;
            const total = state.tasks.length;
            const pctToday = total === 0 ? 0 : Math.round((state.tasks.filter(t => t.completed).length / total) * 100);
            const labels = state.history.map(h => h.date.split('/').slice(0,2).join('/')).concat(['NOW']);
            let data = currentView === 'daily' ? state.history.map(h => h.percentage).concat([pctToday]) : state.history.map((h, i, arr) => Math.round(arr.slice(0,i+1).reduce((s,x)=>s+x.percentage,0)/(i+1))).concat([Math.round((state.history.reduce((s,h)=>s+h.percentage,0)+pctToday)/(state.history.length+1))]);
            chartInstance.data.labels = labels;
            chartInstance.data.datasets[0].data = data;
            chartInstance.update();
        }

        let isFocusMode = false;
        function toggleFocusMode() {
            isFocusMode = !isFocusMode;
            const dash = document.getElementById('dashboard');
            const focus = document.getElementById('focus-mode');
            if (isFocusMode) {
                dash.classList.add('opacity-0', 'pointer-events-none');
                setTimeout(() => { dash.classList.add('hidden'); focus.classList.remove('hidden'); setTimeout(() => focus.classList.remove('opacity-0', 'pointer-events-none'), 50); }, 500);
            } else {
                focus.classList.add('opacity-0', 'pointer-events-none');
                setTimeout(() => { focus.classList.add('hidden'); dash.classList.remove('hidden'); setTimeout(() => dash.classList.remove('opacity-0', 'pointer-events-none'), 50); }, 500);
            }
        }
        window.onload = init;
    </script>
</body>
</html>
